{
  "compilerOptions": {
    "target": "ES2022",                 /* Specify ECMAScript target version: 'ES3' (default), 'ES5', 'ES2015', 'ES2016', 'ES2017', 'ES2018', 'ES2019', 'ES2020', 'ES2021', 'ES2022', 'ESNext'. */
    "module": "ESNext",                 /* Emit modern ESM for the staged TypeScript intelligence modules. */
    "moduleResolution": "Bundler",      /* Allow extensionless local TypeScript imports during type-checking. */
    "lib": ["ES2022"],                  /* Specify a library file to be included in the compilation. */
    "types": ["node"],                  /* Specify type package names to be included without being referenced in a source file. */
    "esModuleInterop": true,            /* Enables emit interoperability between CommonJS and ES Modules via creation of namespace objects for all imports. Implies 'allowSyntheticDefaultImports'. */
    "allowSyntheticDefaultImports": true, /* Allow default imports from modules with no default export. This does not affect code emit, just typechecking. */
    "resolveJsonModule": true,          /* Enable importing .json files. */
    "isolatedModules": true,            /* Ensure that each file can be safely transpiled without relying on other imports. */
    "skipLibCheck": true,               /* Skip type checking all .d.ts files. */
    "strict": true,                     /* Enable all strict type-checking options. */
    "noUncheckedIndexedAccess": true,   /* Check for undefined when accessing indexed types. */
    "forceConsistentCasingInFileNames": true, /* Ensure that casing is correct in imports. */
    "outDir": "./dist",                 /* Redirect output structure to the directory. */
    "rootDir": "./",                    /* Specify the root directory of input files. */
    "declaration": true,                /* Generate .d.ts files. */
    "sourceMap": true,                  /* Generate corresponding .map files. */
    "noEmitOnError": true,              /* Do not emit outputs if any errors were reported. */
    "noUnusedLocals": false,            /* Experimental intelligence modules may keep forward-looking imports. */
    "noUnusedParameters": false,        /* Keep API-compatible signatures during staged rollout. */
    "noImplicitReturns": false,         /* Express handlers may return responses conditionally. */
    "noFallthroughCasesInSwitch": true  /* Report errors for fallthrough cases in switch statement. */
  },
  "include": ["**/*.ts"],               /* Specify files to include in compilation. */
  "exclude": ["node_modules", "dist"]   /* Specify files to exclude from compilation. */
}
